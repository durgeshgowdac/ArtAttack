  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Charcoal has unique meanings in Korean tradition. It is believed that
    charcoal can dehumidify houses and ward off evil forces. When the first full
    moon of the lunar calendar rises, people would perform the ritual of \u201Cburning
    the moon house\u201D, setting ablaze a sacred moon structure built up of pine
    branches. The charcoal carbonized by the burning of pine wood is considered a
    purifying substance with spiritual implications."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: bf7cf387dbc9c4f0ea91c95c999011e1, type: 2}
  m_sharedMaterial: {fileID: 8610576823366840524, guid: bf7cf387dbc9c4f0ea91c95c999011e1, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
  m_fontMaterials: []
